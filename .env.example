ADMIN_PASSWORD=your-secure-password
ADMIN_SESSION_SECRET=your-random-secret-string

# Manyasha (чат-консультант на лендинге)
# API встроен в Next.js: /api/manyasha/chat
# Промпт: prompts/manyasha-prompt.txt
NEXT_PUBLIC_MANYASHA_ENABLED=true
NEXT_PUBLIC_MANYASHA_START_OPEN=false
MANYASHA_LLM_PROVIDER=auto
MANYASHA_LLM_TIMEOUT_SECONDS=12
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite
# MANYASHA_LLM_PROVIDER=fallback — только заготовленные ответы без нейросети
